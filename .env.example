# Server-only Alchemy key (no NEXT_PUBLIC_ prefix — not exposed to client bundle).
# Used for admin NFT queries (getOwnersForContract). Falls back to NEXT_PUBLIC_ALCHEMY_ID.
ALCHEMY_SERVER_KEY=

# AES-256-GCM key for encrypting PII fields (contact_email, contact_telegram).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 64 hex chars (32 bytes). NEVER commit this value.
ENCRYPTION_KEY=

