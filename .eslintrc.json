{
  "extends": ["next/core-web-vitals"],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "rules": {
    "@typescript-eslint/no-explicit-any": "warn",
    "@typescript-eslint/no-unused-vars": "warn",
    "react-hooks/exhaustive-deps": "warn",
    // eslint-plugin-react-hooks canary build (bundled with eslint-config-next@15.0.0-rc.0)
    // crashes with "a.getScope is not a function" on ESLint 9.x.
    // Downgrade to "warn" to allow builds; upgrade eslint-config-next to fix root cause.
    "react-hooks/rules-of-hooks": "warn"
  }
}
