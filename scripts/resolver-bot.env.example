# SuperGuild Resolver Bot — Environment Variables
# Copy this to .env and fill in real values

# Private key of the resolver hot wallet (must be the same address set as resolver in GuildEscrow)
# ALSO needs MINTER_ROLE on VCPTokenV2 to mint VCP rewards
RESOLVER_PRIVATE_KEY=0x...

# Supabase credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# (Optional) Custom RPC URL for Arbitrum Sepolia
# ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
